# Copy this file to .env before running Docker Compose.

# Images
POSTGRES_IMAGE=postgres:16-alpine
GARAGE_IMAGE=dxflrs/garage:v1.1.0

# Host ports
POSTGRES_PORT=5432
GARAGE_S3_PORT=3900
GARAGE_RPC_PORT=3901
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903
BACKEND_PORT=8000
WEB_PORT=3001

# PostgreSQL
POSTGRES_DB=ameo
POSTGRES_USER=ameo
POSTGRES_PASSWORD=ameo_dev_password
DATABASE_URL=postgresql+psycopg://ameo:ameo_dev_password@postgres:5432/ameo

# Garage / S3-compatible attachment storage
S3_ENDPOINT=http://garage:3900
S3_BUCKET=attachments
S3_ACCESS_KEY=replace-with-garage-access-key-id
S3_SECRET_KEY=replace-with-garage-secret-access-key
S3_REGION=garage
S3_FORCE_PATH_STYLE=true

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
