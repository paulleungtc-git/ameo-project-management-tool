# Copy this file to .env before running Docker Compose.

# Images
POSTGRES_IMAGE=postgres:16-alpine
GARAGE_IMAGE=dxflrs/garage:v1.1.0

# Host ports
POSTGRES_PORT=5432
GARAGE_S3_PORT=3900
GARAGE_RPC_PORT=3901
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903
BACKEND_PORT=8000
WEB_PORT=3001

# PostgreSQL
POSTGRES_DB=ameo
POSTGRES_USER=ameo
POSTGRES_PASSWORD=ameo_dev_password
DATABASE_URL=postgresql+psycopg://ameo:ameo_dev_password@postgres:5432/ameo

# Garage / S3-compatible attachment storage
S3_ENDPOINT=http://garage:3900
S3_BUCKET=attachments
S3_ACCESS_KEY=GK414d454f4445564143434553
S3_SECRET_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
S3_REGION=garage
S3_FORCE_PATH_STYLE=true
ATTACHMENT_MAX_BYTES=10485760
ATTACHMENT_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain,text/markdown,text/csv,application/zip

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
